@model CourtDiary.Models.User
@{
    ViewData["Title"] = "Profile";
}

<div class="container py-2">
    <!-- Profile Card -->
    <div class="card shadow mx-auto" style="max-width:400px">

        <div class="bg-primary rounded" style="height:60px"></div>

        <div class="card-body text-center">

            <img src="@(!string.IsNullOrEmpty(Model.avatar) ? Model.avatar : "/images/user.jpg")"
                 alt="User"
                 style="width:100px; height:100px; border-radius:50%; margin-top:-50px; border:3px solid #fff; object-fit: cover;">

            <h4 class="mt-3">@Model.name</h4>
            <p class="text-muted">@(Model.role == 1 ? "Administrator" : "Lawyer")</p>

            <hr>

            <div class="text-left">
                <p><strong>Email:</strong> @Model.email</p>
                <hr>
                <p><strong>Mobile No:</strong> @Model.office_phone_no</p>
                <hr>
                <p><strong>Member Since:</strong> @Model.created_at.ToString("MMMM yyyy")</p>
            </div>

            <div class="d-flex justify-content-between mt-3">
                <a class="btn btn-outline-primary px-4 py-1" asp-controller="Profile" asp-action="Edit">Edit Profile</a>
                <a class="btn btn-outline-secondary px-4 py-1" asp-controller="Profile" asp-action="Changepassword">Security</a>
            </div>
        </div>
    </div>

    <!-- Office Details -->
    <div class="card shadow mt-4" style="max-width:400px; margin:40px auto;">
        <div class="card-header bg-primary text-white">
            Office Details
        </div>
        <div class="card-body">
            <p><i class="fas fa-phone mr-1"></i> <b>Office Contact</b></p>
            <p>@(Model.office_phone_no ?? "N/A")</p>
            <hr>
            <p><i class="fas fa-map-marker-alt mr-1"></i> <b>Office Address</b></p>
            <p>@(Model.office_address ?? "N/A")</p>
            <hr>
            <p><i class="fas fa-envelope mr-1"></i> <b>Work Mail</b></p>
            <p>@Model.email</p>
        </div>
    </div>

</div>
