
@{
    ViewData["Title"] = "Changepassword";
}

    <div class="container py-2">

        <!-- Profile Card -->
    <div class="card shadow mx-auto" style="max-width:400px">

        <div class="bg-primary rounded " style="height:60px"></div>

        <div class="card-body text-center">

            <img src="~/images/user.jpg"
                 alt="User"
                 style="width:100px; height:100px; border-radius:50%; margin-top:-50px; border:3px solid #fff;">

                <h4 class="mt-3">Krisha Shira</h4>
                <p class="text-muted">Criminal Lawyer</p>

                <hr>

                <div class="text-left">
                    <p><strong>Email:</strong> krisha@gmail.com</p>
                    <hr>
                    <p><strong>Mobile No:</strong> 5433456867</p>
                    <hr>
                    <p><strong>Member Since:</strong> 2021</p>
                </div>


            </div>
        </div>

        <!-- change password -->
    <div class="card shadow mt-4" style="max-width:400px; margin:40px auto;">

        <div class="card-header bg-primary text-white">
            Change Password
        </div>
            <div class="card-body">
                <p><i class="fas fa-key me-2"></i> <b>Old Password</b></p><p>
                    <input type="text" class="form-control custom-input"
                           >
                </p>
                <hr>
                <p><i class="fas fa-key me-2"></i> <b>New Password</b></p><p>
                    <input type="text" class="form-control custom-input"
                           >
                </p>
                <hr>
                <p><i class="fas fa-key me-2"></i><b>Confirm Password</b> <p>
                    <input type="text" class="form-control custom-input"
                           >
                </p>
                <a class="btn btn-primary w-100" asp-controller="Profile" asp-action="Index">Save</a>
            </div>
        </div>

    </div>


