
@{
    ViewData["Title"] = "changepassword";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>User Profile</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">



    <style>
        body {
            background-color: #f4f6f9;
        }

        .profile-card {
            max-width: 400px;
            margin: 40px auto;
        }

        .profile-img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            margin-top: -50px;
            border: 3px solid #fff;
        }

        .header-bg {
            height: 60px;
            background: #007bff;
            border-top-left-radius: 5px;
            border-top-right-radius: 5px;
        }
    </style>
</head>
<body>

    <div class="container">

        <!-- Profile Card -->
        <div class="card profile-card shadow">
            <div class="header-bg"></div>
            <div class="card-body text-center">
                <img src="~/images/user.jpg" class="profile-img" alt="User">

                <h4 class="mt-3">Nina Mcintire</h4>
                <p class="text-muted">Criminal Lawyer</p>

                <hr>

                <div class="text-left">
                    <p><strong>Email:</strong> nina23@gmail.com</p>
                    <hr>
                    <p><strong>Mobile No:</strong> 5433456867</p>
                    <hr>
                    <p><strong>Member Since:</strong> 2021</p>
                </div>


            </div>
        </div>

        <!-- change password -->
        <div class="card profile-card shadow mt-4">
            <div class="card-header bg-primary text-white">
                Change Password
            </div>
            <div class="card-body">
                <p><i class="fas fa-key me-2"></i> <b>Old Password</b></p><p>
                    <input type="text" class="form-control custom-input"
                           >
                </p>
                <hr>
                <p><i class="fas fa-key me-2"></i> <b>New Password</b></p><p>
                    <input type="text" class="form-control custom-input"
                           >
                </p>
                <hr>
                <p><i class="fas fa-key me-2"></i><b>Confirm Password</b> <p>
                    <input type="text" class="form-control custom-input"
                           >
                </p>
                <button class="btn btn-primary w-100">Save</button>
            </div>
        </div>

    </div>

</body>
</html>

