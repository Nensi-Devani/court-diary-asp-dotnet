@{
    ViewData["Title"] = "Security";
}

<div class="container py-2">

    <!-- Success/Error Messages -->
    @if (ViewBag.Message != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-auto" style="max-width:400px">
            @ViewBag.Message
            <button type="button" class="close" data-dismiss="alert">&times;</button>
        </div>
    }
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mx-auto" style="max-width:400px">
            @ViewBag.Error
            <button type="button" class="close" data-dismiss="alert">&times;</button>
        </div>
    }

    <!-- Change Password Form -->
    <div class="card shadow mt-4 mx-auto" style="max-width:400px;">
        <div class="card-header bg-primary text-white">
            <i class="fas fa-lock mr-2"></i> Change Password
        </div>
        <div class="card-body">
            <form method="post" asp-controller="Profile" asp-action="Changepassword">
                <div class="form-group">
                    <label><i class="fas fa-key mr-2"></i> Old Password</label>
                    <input type="password" name="OldPassword" class="form-control" required>
                </div>
                <hr>
                <div class="form-group">
                    <label><i class="fas fa-key mr-2"></i> New Password</label>
                    <input type="password" name="NewPassword" class="form-control" required minlength="6">
                </div>
                <hr>
                <div class="form-group">
                    <label><i class="fas fa-key mr-2"></i> Confirm New Password</label>
                    <input type="password" name="ConfirmPassword" class="form-control" required minlength="6">
                </div>
                <br>
                <div class="d-flex">
                    <a class="btn btn-outline-secondary w-50 mr-2" asp-controller="Profile" asp-action="Index">Cancel</a>
                    <button type="submit" class="btn btn-primary w-50">Update Password</button>
                </div>
            </form>
        </div>
    </div>

</div>


