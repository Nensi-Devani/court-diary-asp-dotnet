@model CourtDiary.Models.User
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="container py-2">

    <form method="post" asp-controller="Profile" asp-action="Edit">
        <!-- Profile Overview (Non-editable part in this view, or add fields if needed) -->
        <div class="card shadow mx-auto" style="max-width:400px">
            <div class="bg-primary rounded" style="height:60px"></div>
            <div class="card-body text-center">
                <img src="@(!string.IsNullOrEmpty(Model.avatar) ? Model.avatar : "/images/user.jpg")"
                     alt="User"
                     style="width:100px; height:100px; border-radius:50%; margin-top:-50px; border:3px solid #fff; object-fit: cover;">

                <div class="mt-3">
                    <label class="small text-muted mb-0">Full Name</label>
                    <input type="text" name="name" class="form-control text-center font-weight-bold" value="@Model.name" required>
                </div>
                <p class="text-muted mt-2">@(Model.role == 1 ? "Administrator" : "Lawyer")</p>
                <hr>
                <div class="text-left small">
                    <p><strong>Email:</strong> @Model.email</p>
                    <p><strong>Member Since:</strong> @Model.created_at.ToString("MMMM yyyy")</p>
                </div>
            </div>
        </div>

        <!-- Office Details (Editable) -->
        <div class="card shadow mt-4" style="max-width:400px; margin:40px auto;">
            <div class="card-header bg-primary text-white">
                Edit Office Details
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label>Office Address</label>
                    <textarea name="office_address" class="form-control" rows="2">@Model.office_address</textarea>
                </div>
                <hr>
                <div class="form-group">
                    <label>Mobile Number</label>
                    <input type="text" name="office_phone_no" class="form-control" value="@Model.office_phone_no">
                </div>
                <br>
                <div class="d-flex">
                    <a class="btn btn-outline-secondary w-50 mr-2" asp-controller="Profile" asp-action="Index">Cancel</a>
                    <button type="submit" class="btn btn-primary w-50">Save Changes</button>
                </div>
            </div>
        </div>
    </form>

</div>
