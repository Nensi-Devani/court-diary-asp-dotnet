@model CourtDiary.Models.Case
@{
ViewData["Title"] = "Add Case";
}

<div class="container-fluid">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">

                <!-- Page Title (Left Side) -->
                <div class="col-sm-6">
                    <h4 class="m-0">Add Case</h4>
                </div>

                <!-- Breadcrumb (Right Side) -->
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/Cases/Index">Cases</a></li>
                        <li class="breadcrumb-item active">Add Case</li>
                    </ol>
                </div>

            </div>
        </div>
    </div>
    <form action="/Cases/Create" method="post" enctype="multipart/form-data">
        <input type="hidden" name="client_id" id="client_id" value="">

        <!-- Case Details -->
        <div class="card mx-4 mb-4">
            <div class="card-body">

                <h5><b>Case Details:</b></h5>

                <div class="row mt-3">

                    <div class="col ">
                        <label>Case No</label>
                        <input type="text" name="case_no" class="form-control">
                    </div>

                    <div class="col-md-5 mb-3">
                        <label>Case Title</label>
                        <input type="text" name="title" class="form-control">
                    </div>

                    <div class="col-md-3 mb-3">
                        <label>Status</label>
                        <select name="status" class="form-control">
                            <option value="Active">Active</option>
                            <option value="Pending">Pending</option>
                            <option value="Closed">Closed</option>
                        </select>
                    </div>


                    <div class="col-md-6 mb-3">
                        <label>Case First Hearing</label>
                        <input type="date" class="form-control" name="firstHearingDate">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Case Next Hearing</label>
                        <input type="date" class="form-control" name="nextHearingDate">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Previous Hearing</label>
                        <input type="date" class="form-control" name="previousHearingDate">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Location</label>
                        <input type="text" name="location" class="form-control">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Hearing Notes</label>
<textarea class="form-control" name="hearing_notes" rows="3"></textarea>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Previous Hearing Summary</label>
<textarea class="form-control" name="previous_hearing_summary" rows="3"></textarea>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label>Case Description</label>
<textarea class="form-control" name="description" rows="3"></textarea>
                    </div>

                </div>

            </div>
        </div>


        <!-- Document Section -->
        <div class="card mx-4 mb-4">
            <div class="card-body">

                <h5><b>Document:</b></h5>

                <div class="row mt-3 align-items-center">

                    <div class="col-md-6">
                        <input type="file" name="uploadedFiles" class="form-control-file w-100" multiple>
                    </div>

                    <div class="col-md-6 text-md-right mt-2 mt-md-0">
                        <select name="docCategory" class="form-control d-inline-block w-auto">
                            <option value="1">Court</option>
                            <option value="2">Evidence</option>
                            <option value="3">Client</option>
                        </select>
                    </div>

                </div>

            </div>
        </div>


        <!-- Opposite Party -->
        <!-- Opposite Party -->
        <div class="card mx-4 mb-4">
            <div class="card-body">

                <h5><b>Opposite Party Details:</b></h5>

                <div class="row mt-3">

                    <!-- Opposite Party -->
                    <div class="col-md-6 text-center">

                        <img src="~/images/user.jpg" id="oppPartyImgPreview" width="90" class="img-circle mb-2">

                        <br>

                        <input type="file" id="party" name="oppPartyAvatarFile" class="d-none" onchange="document.getElementById('oppPartyImgPreview').src = window.URL.createObjectURL(this.files[0])">
                        <label for="party" class="btn btn-secondary btn-sm">Choose</label>

                        <div class="mt-3 text-left">

                            <label>Opposite Party Name</label>
                            <input type="text" name="oppPartyName" class="form-control">

                            <label class="mt-2">Other Notes (Opp. party)</label>
                            <textarea class="form-control" name="oppPartyNotes" rows="2"></textarea>

                        </div>

                    </div>


                    <!-- Opposite Party Lawyer -->
                    <div class="col-md-6 text-center">

                        <img src="~/images/user.jpg" id="oppLawyerImgPreview" width="90" class="img-circle mb-2">

                        <br>

                        <input type="file" id="lawyer" name="oppLawyerAvatarFile" class="d-none" onchange="document.getElementById('oppLawyerImgPreview').src = window.URL.createObjectURL(this.files[0])">
                        <label for="lawyer" class="btn btn-secondary btn-sm">Choose</label>

                        <div class="mt-3 text-left">

                            <label>Opposite Party's Lawyer Name</label>
                            <input type="text" name="oppLawyerName" class="form-control">

                            <label class="mt-2">Other Notes (Lawyer)</label>
                            <textarea class="form-control" name="oppLawyerNotes" rows="2"></textarea>

                        </div>

                    </div>

                </div>

            </div>
        </div>


        <!-- Client Details -->
        <div class="card mx-4 mb-4">
            <div class="card-body">

                <h5><b>Client Details:</b></h5>

                <div class="row mt-3">
                    <!-- Left Side -->
                    <div class="col-md-6">
                        <div class="text-center mb-3">
                            <img src="~/images/user.jpg" id="clientDetailsAvatar" class="img-circle elevation-2" width="100">
                        </div>
                        <label>Client Name</label>
                        <input type="text" class="form-control" id="clientDetailsName" readonly>

                        <label class="mt-3">Other Notes</label>
                        <textarea class="form-control" id="clientDetailsNotes" rows="3" readonly></textarea>
                    </div>

                    <!-- Right Side -->
                    <div class="col-md-6">
                        <!-- Invisible space to align with image -->
                        <div style="height:120px;"></div>

                        <label>Mobile No</label>
                        <input type="text" class="form-control" id="clientDetailsPhone" readonly>

                        <label class="mt-3">Address</label>
                        <textarea class="form-control" id="clientDetailsAddress" rows="3" readonly></textarea>
                    </div>
                </div>

                <button type="button" class="btn btn-success mt-3" data-toggle="modal" data-target="#clientModal">
                    Choose Client
                </button>

            </div>
        </div>


        <!-- Client Modal -->
        <div class="modal fade" id="clientModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">

                    <!-- Modal Header -->
                    <div class="modal-header">
                        <h5 class="modal-title">Select Client</h5>
                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                    </div>

                    <!-- Modal Body -->
                    <div class="modal-body p-0" style="max-height:400px; overflow-y:auto;">

                        <table class="table table-striped w-100 text-center">

                            <thead>
                                <tr>
                                    <th>Sr No</th>
                                    <th>Client</th>
                                    <th>Client Name</th>
                                    <th>Mobile</th>
                                    <th>Active Cases</th>
                                    <th>Action</th>
                                </tr>
                            </thead>

                            <tbody>

                                @if (ViewBag.Clients != null)
                                {
                                    int i = 1;
                                    foreach (var client in ViewBag.Clients)
                                    {
                                        <tr>
                                            <td>@i</td>
                                            <td>
                                                <img src="@(string.IsNullOrEmpty(client.avatar) ? (string.IsNullOrEmpty(client.ImagePath) ? "/images/user.jpg" : client.ImagePath) : client.avatar)" style="width:40px;height:40px;border-radius:10%;">
                                            </td>
                                            <td>@client.name</td>
                                            <td>@client.phone</td>
                                            <td>
                                                <span class="badge bg-success">0</span>
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-primary" onclick="selectClient(@client.client_id)" data-dismiss="modal">
                                                    Select
                                                </button>
                                            </td>
                                        </tr>
                                        i++;
                                    }
                                }

                            </tbody>

                        </table>

                    </div>

                    <!-- Modal Footer -->
                    <div class="modal-footer">

                        <button class="btn btn-secondary" data-dismiss="modal">
                            Close
                        </button>

                    </div>

                </div>
            </div>
        </div>


        <!-- Submit Button -->
        <div class="text-center mb-4">

            <button type="submit" class="btn btn-primary px-4 mb-4">
                Add
            </button>

        </div>

    </form>

</div>

@section Scripts {
    <script>
        function selectClient(id) {
            document.getElementById('client_id').value = id;
            fetch('/Cases/GetClient/' + id)
                .then(response => response.json())
                .then(data => {
                    document.getElementById('clientDetailsName').value = data.name;
                    document.getElementById('clientDetailsPhone').value = data.phone;
                    document.getElementById('clientDetailsNotes').value = data.description || '';
                    document.getElementById('clientDetailsAddress').value = data.address;
                    document.getElementById('clientDetailsAvatar').src = data.avatar;
                })
                .catch(error => console.error('Error fetching client details:', error));
        }
    </script>
}
