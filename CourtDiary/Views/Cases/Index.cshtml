
@model IEnumerable<CourtDiary.Models.Case>
@{
    ViewData["Title"] = "Index";
}

    <div class="container-fluid mt-4">
        <div class="row">
            <div class="col-12">

                <div class="card">

                    <!-- Card Header -->

                    <div class="card-header" style="display:flex; align-items:center;">

                        <h3 class="card-title">Cases</h3>

                        <div class="card-tools" style="margin-left:auto; display:flex; align-items:center; gap:10px;">

                            <!-- Search -->

                            <div class="search-box" style="position:relative; width:180px;">

                                <i class="fas fa-search"
                                   style="position:absolute; top:50%; left:8px; transform:translateY(-50%); color:#6c757d; font-size:14px;"></i>

                                <input type="text" placeholder="Search"
                                       style="width:100%; height:30px; padding-left:30px; border:1px solid #ced4da; border-radius:5px; font-size:14px;">

                            </div>

                            <a href="/Cases/Create"
                               class="btn btn-primary btn-sm">
                                <i class="fas fa-plus"></i> Add New
                            </a>

                        </div>

                    </div>

                    <!-- Card Body -->

                    <div class="card-body table-responsive" style="overflow-x:auto;">

                        <table class="table table-striped text-center" style="white-space:nowrap;">

                            <thead>
                                <tr>
                                    <th>Sr No</th>
                                    <th>Client</th>
                                    <th>Client Name</th>
                                    <th>Case No</th>
                                    <th>Title</th>
                                    <th>Location</th>
                                    <th>Opp.Lawyer</th>
                                    <th>Next Hearing</th>
                                    <th>Uploaded Docs</th>
                                    <th>Payment Status</th>
                                    <th>Case Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var item in Model)
                                {

                                    <tr>
                                        <td>@item.case_id</td>

                                        <td>
                                            <img src="@(item.Client?.avatar ?? item.Client?.ImagePath ?? "/images/user.jpg")"
                                                 class="profile-img"
                                                 style="width:40px; height:40px; border-radius:10%; object-fit: cover;">
                                        </td>

                                        <td>@(item.Client?.name ?? "N/A")</td>
                                        <td>@item.case_no</td>
                                        <td>@item.title</td>
                                        <td>@item.location</td>
                                        <td>@(item.Case_Parties?.FirstOrDefault(p => p.type == "Opposite Party Lawyer")?.name ?? "N/A")</td>
                                        <td>@(item.Hearings?.OrderByDescending(h => h.next_hearing_date).FirstOrDefault(h => h.next_hearing_date != null)?.next_hearing_date?.ToString("dd-MMM-yyyy") ?? "N/A")</td>

                                        <td><span class="badge bg-secondary">@(item.Uploads?.Count ?? 0)</span></td>
                                        <td><span class="badge bg-success">N/A</span></td>
                                        <td><span class="badge bg-success">@(string.IsNullOrEmpty(item.status) ? "Pending" : item.status)</span></td>

                                        <td>

                                            <a href="/Cases/Viewdetails/@item.case_id" class="btn btn-sm btn-info">
                                                <i class="fas fa-eye"></i>
                                            </a>

                                            <a href="/Cases/Edit/@item.case_id" class="btn btn-sm btn-warning">
                                                <i class="fas fa-edit"></i>
                                            </a>

                                            <form action="/Cases/Delete/@item.case_id" method="post" style="display:inline;">
                                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this case?');">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>

                                        </td>

                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>

        </div>
    </div>
