@model CourtDiary.Models.Case
@{
    ViewData["Title"] = "Edit Case";
}

<div class="container-fluid">

    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">

                <div class="col-sm-6">
                    <h4 class="m-0">Edit Case</h4>
                </div>

                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/Cases/Index">Cases</a></li>
                        <li class="breadcrumb-item active">Edit Case</li>
                    </ol>
                </div>

            </div>
        </div>
    </div>

    <form action="/Cases/Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" name="case_id" value="@Model?.case_id" />
        <input type="hidden" name="client_id" id="client_id" value="@Model?.client_id" />

        <!-- Case Details -->
        <div class="card mx-4 mb-4">
            <div class="card-body">

                <h5><b>Case Details:</b></h5>

                <div class="row mt-3">

                    <div class="col-md-6 mb-3">
                        <label>Case No</label>
                        <input type="text" name="case_no" class="form-control" value="@Model?.case_no">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Case Title</label>
                        <input type="text" name="title" class="form-control" value="@Model?.title">
                    </div>

                    @{
                        var currentHearing = Model?.Hearings?.OrderByDescending(h => h.hearing_date).FirstOrDefault();
                    }

                    <div class="col-md-6 mb-3">
                        <label>Case First Hearing</label>
                        <input type="date" class="form-control" name="firstHearingDate" value="@(currentHearing?.hearing_date?.ToString("yyyy-MM-dd"))">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Case Next Hearing</label>
                        <input type="date" class="form-control" name="nextHearingDate" value="@(currentHearing?.next_hearing_date?.ToString("yyyy-MM-dd"))">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Previous Hearing</label>
                        <input type="date" class="form-control" name="previousHearingDate" value="@(Model?.previous_hearing_summary != null ? "2020-01-08" : "")">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Location</label>
                        <input type="text" name="location" class="form-control" value="@Model?.location">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Hearing Notes</label>
<textarea class="form-control" name="hearing_notes" rows="3">
@Model?.hearing_notes
</textarea>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Previous Hearing Summary</label>
<textarea class="form-control" name="previous_hearing_summary" rows="3">
@Model?.previous_hearing_summary
</textarea>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label>Case Description</label>
<textarea class="form-control" name="description" rows="3">
@Model?.description
</textarea>
                    </div>

                </div>

            </div>
        </div>


        <!-- Document Section -->
        <div class="card mx-4 mb-4">
            <div class="card-body">

                <h5><b>Document:</b></h5>

                <div class="row mt-3 align-items-center">
                    
                    <div class="col-md-12 mb-3">
                        @if (Model?.Uploads != null && Model.Uploads.Count > 0)
                        {
                            <p><b>Existing Documents:</b></p>
                            <ul>
                                @foreach (var upload in Model.Uploads)
                                {
                                    <li><a href="@upload.upload_url" target="_blank">View Document (Category: @upload.upload_category)</a></li>
                                }
                            </ul>
                        }
                    </div>

                    <div class="col-md-6">
                        <input type="file" name="uploadedFiles" class="form-control-file w-100" multiple>
                    </div>

                    <div class="col-md-6 text-md-right mt-2 mt-md-0">
                        <select name="docCategory" class="form-control d-inline-block w-auto">
                            <option value="1">Court</option>
                            <option value="2">Evidence</option>
                            <option value="3">Client</option>
                        </select>
                    </div>

                </div>

            </div>
        </div>


        <!-- Opposite Party -->
        <div class="card mx-4 mb-4">
            <div class="card-body">
                <h5><b>Opposite Party Details:</b></h5>

                @{
                    var oppParty = Model?.Case_Parties?.FirstOrDefault(p => p.type == "Opposite Party");
                    var oppLawyer = Model?.Case_Parties?.FirstOrDefault(p => p.type == "Opposite Party Lawyer");
                }

                <div class="row mt-3">
                    <!-- Opposite Party -->
                    <div class="col-md-6 text-center">
                        <img src="@(oppParty?.avatar ?? "/images/user.jpg")" id="oppPartyImgPreview" width="90" class="img-circle mb-2">
                        <br>
                        <!-- No file upload for editing parties to keep it simple, or we can add it -->
                        <div class="mt-3 text-left">
                            <label>Opposite Party Name</label>
                            <input type="text" class="form-control" value="@oppParty?.name" readonly>

                            <label class="mt-3">Other Notes (Opp. party)</label>
                            <textarea class="form-control" rows="3" readonly>@oppParty?.notes</textarea>
                        </div>
                    </div>

                    <!-- Opposite Party Lawyer -->
                    <div class="col-md-6 text-center">
                        <img src="@(oppLawyer?.avatar ?? "/images/user.jpg")" id="oppLawyerImgPreview" width="90" class="img-circle mb-2">
                        <br>
                        <div class="mt-3 text-left">
                            <label>Opposite Party's Lawyer Name</label>
                            <input type="text" class="form-control" value="@oppLawyer?.name" readonly>

                            <label class="mt-3">Other Notes (Lawyer)</label>
                            <textarea class="form-control" rows="3" readonly>@oppLawyer?.notes</textarea>
                        </div>
                    </div>
                </div>

            </div>
        </div>


        <!-- Client Details -->
        <div class="card mx-4 mb-4">
            <div class="card-body">

                <h5><b>Client Details:</b></h5>

                <div class="row mt-3">

                    <!-- Left Side -->
                    <div class="col-md-6">

                        <div class="text-center mb-3">
                            <img src="@(Model?.Client?.avatar ?? Model?.Client?.ImagePath ?? "/images/user.jpg")" id="clientDetailsAvatar" class="img-circle elevation-2" width="100">
                        </div>

                        <label>Client Name</label>
                        <input type="text" class="form-control" id="clientDetailsName" value="@Model?.Client?.name" readonly>

                        <label class="mt-3">Other Notes</label>
                        <textarea class="form-control" id="clientDetailsNotes" rows="3" readonly>@Model?.Client?.description</textarea>

                    </div>


                    <!-- Right Side -->
                    <div class="col-md-6">

                        <!-- Invisible space to align with image -->
                        <div style="height:120px;"></div>

                        <label>Mobile No</label>
                        <input type="text" class="form-control" id="clientDetailsPhone" value="@Model?.Client?.phone" readonly>

                        <label class="mt-3">Address</label>
                        <textarea class="form-control" id="clientDetailsAddress" rows="3" readonly>@Model?.Client?.address</textarea>

                    </div>

                </div>

                <button type="button" class="btn btn-success mt-3" data-toggle="modal" data-target="#clientModal">
                    Change Client
                </button>

            </div>
        </div>


        <!-- Client Modal -->
        <div class="modal fade" id="clientModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">

                    <!-- Modal Header -->
                    <div class="modal-header">
                        <h5 class="modal-title">Select Client</h5>
                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                    </div>

                    <!-- Modal Body -->
                    <div class="modal-body p-0" style="max-height:400px; overflow-y:auto;">

                        <table class="table table-striped w-100 text-center">

                            <thead>
                                <tr>
                                    <th>Sr No</th>
                                    <th>Client</th>
                                    <th>Client Name</th>
                                    <th>Mobile</th>
                                    <th>Active Cases</th>
                                    <th>Action</th>
                                </tr>
                            </thead>

                            <tbody>

                                @if (ViewBag.Clients != null)
                                {
                                    int i = 1;
                                    foreach (var client in ViewBag.Clients)
                                    {
                                        <tr>
                                            <td>@i</td>
                                            <td>
                                                <img src="@(string.IsNullOrEmpty(client.avatar) ? (string.IsNullOrEmpty(client.ImagePath) ? "/images/user.jpg" : client.ImagePath) : client.avatar)" style="width:40px;height:40px;border-radius:10%;">
                                            </td>
                                            <td>@client.name</td>
                                            <td>@client.phone</td>
                                            <td>
                                                <span class="badge bg-success">0</span>
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-primary" onclick="selectClient(@client.client_id)" data-dismiss="modal">
                                                    Select
                                                </button>
                                            </td>
                                        </tr>
                                        i++;
                                    }
                                }

                            </tbody>

                        </table>

                    </div>

                    <!-- Modal Footer -->
                    <div class="modal-footer">

                        <button class="btn btn-secondary" data-dismiss="modal">
                            Close
                        </button>

                    </div>

                </div>
            </div>
        </div>


        <!-- Update Button -->
        <div class="text-center mb-4">

            <button type="submit" class="btn btn-primary px-4 mb-4">
                Update
            </button>

        </div>

    </form>

</div>

@section Scripts {
    <script>
        function selectClient(id) {
            document.getElementById('client_id').value = id;
            fetch('/Cases/GetClient/' + id)
                .then(response => response.json())
                .then(data => {
                    document.getElementById('clientDetailsName').value = data.name;
                    document.getElementById('clientDetailsPhone').value = data.phone;
                    document.getElementById('clientDetailsNotes').value = data.description || '';
                    document.getElementById('clientDetailsAddress').value = data.address;
                    document.getElementById('clientDetailsAvatar').src = data.avatar;
                })
                .catch(error => console.error('Error fetching client details:', error));
        }
    </script>
}