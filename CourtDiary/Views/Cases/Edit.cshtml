@{
    ViewData["Title"] = "Edit Case";
}

<div class="container-fluid">

    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">

                <div class="col-sm-6">
                    <h4 class="m-0">Edit Case</h4>
                </div>

                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/Cases/Index">Cases</a></li>
                        <li class="breadcrumb-item active">Edit Case</li>
                    </ol>
                </div>

            </div>
        </div>
    </div>

    <form>

        <!-- Case Details -->
        <div class="card mx-4 mb-4">
            <div class="card-body">

                <h5><b>Case Details:</b></h5>

                <div class="row mt-3">

                    <div class="col-md-6 mb-3">
                        <label>Case No</label>
                        <input type="text" class="form-control" value="35670158">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Case Title</label>
                        <input type="text" class="form-control" value="Property">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Case First Hearing</label>
                        <input type="date" class="form-control" value="2020-01-09">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Case Next Hearing</label>
                        <input type="date" class="form-control" value="2020-01-12">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Previous Hearing</label>
                        <input type="date" class="form-control" value="2020-01-08">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Location</label>
                        <input type="text" class="form-control" value="Mumbai District Civil Court">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Hearing Notes</label>
<textarea class="form-control" rows="3">
Both parties were present. Court requested property documents.
</textarea>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Previous Hearing Summary</label>
<textarea class="form-control" rows="3">
Defendant requested additional time to submit statement.
</textarea>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label>Case Description</label>
<textarea class="form-control" rows="3">
This case relates to a property ownership dispute.
</textarea>
                    </div>

                </div>

            </div>
        </div>


        <!-- Document Section -->
        <!-- Document Section -->
        <div class="card mx-4 mb-4">
            <div class="card-body">

                <h5><b>Document:</b></h5>

                <div class="row mt-3 align-items-center">

                    <!-- PDF Files -->
                    <div class="col-md-6 d-flex">

                        <div class="text-center mr-3 position-relative">

                            <i class="fas fa-file-pdf fa-3x text-secondary"></i>

                            <span class="badge badge-danger position-absolute"
                                  style="top:-8px; right:-8px; cursor:pointer;">
                                <i class="fas fa-times"></i>
                            </span>

                         

                        </div>


                        <div class="text-center mr-3 position-relative">

                            <i class="fas fa-file-pdf fa-3x text-secondary"></i>

                            <span class="badge badge-danger position-absolute"
                                  style="top:-8px; right:-8px; cursor:pointer;">
                                <i class="fas fa-times"></i>
                            </span>


                        </div>


                        <div class="text-center mr-3 position-relative">

                            <i class="fas fa-file-pdf fa-3x text-secondary"></i>

                            <span class="badge badge-danger position-absolute"
                                  style="top:-8px; right:-8px; cursor:pointer;">
                                <i class="fas fa-times"></i>
                            </span>

                            

                        </div>

                    </div>


                    <!-- Buttons -->
                    <div class="col-md-6 text-md-right">

                        <button class="btn btn-primary btn-sm mr-2">Court</button>
                        <button class="btn btn-danger btn-sm mr-2">Evidence</button>
                        <button class="btn btn-warning btn-sm">Client</button>

                    </div>

                </div>

            </div>
        </div>


        <!-- Opposite Party -->
        <!-- Opposite Party -->
        <div class="card mx-4 mb-4">
            <div class="card-body">

                <h5><b>Opposite Party Details:</b></h5>

                <div class="row mt-3">

                    <!-- Opposite Party -->
                    <div class="col-md-6">

                        <div class="text-center mb-3">
                            <img src="~/images/user.jpg" width="100" class="img-circle">
                        </div>

                        <label>Opposite Party Name</label>
                        <input type="text" class="form-control" value="Amit Verma">

                        <label class="mt-3">Other Notes (Opp. party)</label>
                        <textarea class="form-control" rows="3">
Defendant claims ancestral ownership of the disputed property.
</textarea>

                    </div>


                    <!-- Opposite Party Lawyer -->
                    <div class="col-md-6">

                        <div class="text-center mb-3">
                            <img src="~/images/user.jpg" width="100" class="img-circle">
                        </div>

                        <label>Opposite Party's Lawyer Name</label>
                        <input type="text" class="form-control" value="Adv. Neeraj Kulkarni">

                        <label class="mt-3">Other Notes (Lawyer)</label>
                        <textarea class="form-control" rows="3">
Opposite counsel requested adjournment in last hearing.
</textarea>

                    </div>

                </div>

            </div>
        </div>


        <!-- Client Details -->
        <!-- Client Details -->
        <div class="card mx-4 mb-4">
            <div class="card-body">

                <h5><b>Client Details:</b></h5>

                <div class="row mt-3">

                    <!-- Left Side -->
                    <div class="col-md-6">

                        <!-- Image Section -->
                        <div class="text-center mb-3">
                            <img src="~/images/user.jpg" class="img-circle elevation-2" width="100">
                        </div>

                        <label>Client Name</label>
                        <input type="text" class="form-control" value="Amit Verma">

                        <label class="mt-3">Other Notes</label>
                        <textarea class="form-control" rows="3">
Client provided original sale deed copy.
</textarea>

                    </div>


                    <!-- Right Side -->
                    <div class="col-md-6">

                        <!-- Invisible space to align with image -->
                        <div style="height:120px;"></div>

                        <label>Mobile No</label>
                        <input type="text" class="form-control" value="+91 9876543210">

                        <label class="mt-3">Address</label>
                        <textarea class="form-control" rows="3">
Flat No 402, Shanti Residency,
MG Road, Andheri East, Mumbai
</textarea>

                    </div>

                </div>

            </div>
        </div>


        <!-- Update Button -->
        <div class="text-center mb-4">

            <button type="submit" class="btn btn-primary px-4 mb-4">
                Update
            </button>

        </div>

    </form>

</div>