@model CourtDiary.Models.Case
@{
    ViewData["Title"] = "Viewdetails";
}


<div class="container-fluid">

    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">

                <div class="col-sm-6">
                    <h4 class="m-0">View Case</h4>
                </div>

                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/Cases/Index">Cases</a></li>
                        <li class="breadcrumb-item active">View Case</li>
                    </ol>
                </div>

            </div>
        </div>
    </div>

    <form>

        <!-- Case Details -->
        <div class="card mx-4 mb-4">
            <div class="card-body">

                <h5><b>Case Details:</b></h5>

                <div class="row mt-3">

                    <div class="col-md-6 mb-3">
                        <label>Case No</label>
                        <input type="text" class="form-control" value="@Model?.case_no" readonly>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Case Title</label>
                        <input type="text" class="form-control" value="@Model?.title" readonly>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Case First Hearing</label>
                        <input type="date" class="form-control" value="2020-01-09" readonly>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Case Next Hearing</label>
                        <input type="date" class="form-control" value="2020-01-12" readonly>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Previous Hearing</label>
                        <input type="date" class="form-control" value="2020-01-08" readonly>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Location</label>
                        <input type="text" class="form-control" value="@Model?.location" readonly>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Hearing Notes</label>
<textarea class="form-control" rows="3" readonly>
@Model?.hearing_notes
</textarea>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Previous Hearing Summary</label>
<textarea class="form-control" rows="3" readonly>
@Model?.previous_hearing_summary
</textarea>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label>Case Description</label>
<textarea class="form-control" rows="3" readonly>
@Model?.description
</textarea>
                    </div>

                </div>

            </div>
        </div>


        <!-- Document Section -->
        <div class="card mx-4 mb-4">
            <div class="card-body">

                <h5><b>Document:</b></h5>

                <div class="row mt-3 align-items-center">

                    <div class="col-md-12 mb-3">
                        @if (Model?.Uploads != null && Model.Uploads.Count > 0)
                        {
                            <ul>
                                @foreach (var upload in Model.Uploads)
                                {
                                    <li><a href="@upload.upload_url" target="_blank">View Document (Category: @upload.upload_category)</a></li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p>No documents uploaded.</p>
                        }
                    </div>

                </div>

            </div>
        </div>


        <!-- Opposite Party -->
        <!-- Opposite Party -->
        <div class="card mx-4 mb-4">
            <div class="card-body">

                <h5><b>Opposite Party Details:</b></h5>

                @{
                    var oppParty = Model?.Case_Parties?.FirstOrDefault(p => p.type == "Opposite Party");
                    var oppLawyer = Model?.Case_Parties?.FirstOrDefault(p => p.type == "Opposite Party Lawyer");
                }

                <div class="row mt-3">

                    <!-- Opposite Party -->
                    <div class="col-md-6">

                        <div class="text-center mb-3">
                            <img src="@(oppParty?.avatar ?? "/images/user.jpg")" width="100" class="img-circle">
                        </div>

                        <label>Opposite Party Name</label>
                        <input type="text" class="form-control" value="@oppParty?.name" readonly>

                        <label class="mt-3">Other Notes (Opp. party)</label>
                        <textarea class="form-control" rows="3" readonly>@oppParty?.notes</textarea>

                    </div>


                    <!-- Opposite Party Lawyer -->
                    <div class="col-md-6">

                        <div class="text-center mb-3">
                            <img src="@(oppLawyer?.avatar ?? "/images/user.jpg")" width="100" class="img-circle">
                        </div>

                        <label>Opposite Party's Lawyer Name</label>
                        <input type="text" class="form-control" value="@oppLawyer?.name" readonly>

                        <label class="mt-3">Other Notes (Lawyer)</label>
                        <textarea class="form-control" rows="3" readonly>@oppLawyer?.notes</textarea>

                    </div>

                </div>

            </div>
        </div>


        <!-- Client Details -->
        <!-- Client Details -->
        <div class="card mx-4 mb-4">
            <div class="card-body">

                <h5><b>Client Details:</b></h5>

                <div class="row mt-3">

                    <!-- Left Side -->
                    <div class="col-md-6">

                        <!-- Image Section -->
                        <div class="text-center mb-3">
                            <img src="@(Model?.Client?.avatar ?? Model?.Client?.ImagePath ?? "/images/user.jpg")" class="img-circle elevation-2" width="100">
                        </div>

                        <label>Client Name</label>
                        <input type="text" class="form-control" value="@Model?.Client?.name" readonly>

                        <label class="mt-3">Other Notes</label>
                        <textarea class="form-control" rows="3" readonly>@Model?.Client?.description</textarea>

                    </div>


                    <!-- Right Side -->
                    <div class="col-md-6">

                        <!-- Invisible space to align with image -->
                        <div style="height:120px;"></div>

                        <label>Mobile No</label>
                        <input type="text" class="form-control" value="@Model?.Client?.phone" readonly>

                        <label class="mt-3">Address</label>
                        <textarea class="form-control" rows="3" readonly>@Model?.Client?.address</textarea>

                    </div>

                </div>

            </div>
        </div>

    </form>

</div>

