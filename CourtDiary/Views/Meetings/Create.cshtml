@model CourtDiary.Models.Meeting
@{
    ViewData["Title"] = "Schedule Event";
}

<section class="content-header pb-3">
    <div class="container-fluid">
        <div class="row mb-2 align-items-center">
            <div class="col-sm-6">
                <h1 class="font-weight-bold text-primary m-0">Schedule Event</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-action="Index">Schedule</a></li>
                    <li class="breadcrumb-item active">New Event</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-8 mx-auto">
                <div class="card card-outline card-primary shadow-sm">
                    <div class="card-header">
                        <h3 class="card-title font-weight-bold">Event Details</h3>
                    </div>
                    <form asp-action="Create" method="post">
                        <div class="card-body">
                            <div class="form-group">
                                <label asp-for="Title">Event Title</label>
                                <input asp-for="Title" class="form-control" placeholder="e.g. Client Consultation" required />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Subtitle">Assignee / Client</label>
                                        <input asp-for="Subtitle" class="form-control" placeholder="Name or Email" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Location">Location</label>
                                        <input asp-for="Location" class="form-control" placeholder="Office, Court Room, Zoom, etc." />
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Category">Category</label>
                                        <select asp-for="Category" class="form-control" required>
                                            <option value="">Select Category...</option>
                                            <option value="Hearings & Trials">Hearings & Trials</option>
                                            <option value="Client Meetings">Client Meetings</option>
                                            <option value="Case Prep">Case Prep</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="EventDate">Date & Time</label>
                                        <input asp-for="EventDate" type="datetime-local" class="form-control" required />
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="Description">Description / Notes</label>
                                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Additional details about the event..."></textarea>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="TagText">Priority/Status Tag</label>
                                        <input asp-for="TagText" class="form-control" placeholder="e.g. URGENT, PENDING" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="TagColor">Tag Style</label>
                                        <select asp-for="TagColor" class="form-control">
                                            <option value="primary">Blue (Standard)</option>
                                            <option value="success">Green (Done/Low)</option>
                                            <option value="warning">Yellow (Pending/Medium)</option>
                                            <option value="danger">Red (Urgent/High)</option>
                                            <option value="info">Cyan (Info)</option>
                                            <option value="secondary">Gray (Archive)</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white text-right">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 mr-2">Cancel</a>
                            <button type="submit" class="btn btn-primary px-5 font-weight-bold shadow-sm">
                                <i class="fas fa-check-circle mr-2"></i>Schedule Now
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>