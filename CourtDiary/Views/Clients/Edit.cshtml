@model CourtDiary.Models.Client

@{
    ViewData["Title"] = "Edit Client";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">

            <div class="col-sm-6">
                <h4 class="m-0">Edit Client</h4>
            </div>

            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/Clients/Index">Client</a></li>
                    <li class="breadcrumb-item active">Edit Client</li>
                </ol>
            </div>

        </div>
    </div>
</div>

<div class="card mx-4">
    <div class="card-body">

        <!-- ✅ IMPORTANT -->
        <form method="post" enctype="multipart/form-data">

            <!-- Hidden ID -->
            <input type="hidden" name="client_id" value="@Model.client_id" />

            <!-- IMAGE -->
            <div class="text-center">
                <img id="previewImg"
                     src="@(string.IsNullOrEmpty(Model.ImagePath) ? "/images/user.jpg" : Model.ImagePath)"
                     class="img-fluid img-circle"
                     style="width:125px; height:125px; object-fit:cover;"
                     alt="User">
            </div>

            <!-- Upload -->
            <div class="text-center mt-2">
                <input type="file"
                       name="avatar"
                       id="avatar"
                       class="d-none"
                       accept="image/*"
                       onchange="loadImage(event)" />

                <label for="avatar" class="btn btn-secondary btn-sm px-3">
                    Change Image
                </label>
            </div>

            <div class="row mx-1 my-2">

                <!-- Name -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Client Name</label>
                    <input type="text" name="name" class="form-control" value="@Model.name">
                </div>

                <!-- Phone -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Phone</label>
                    <input type="text" name="phone" class="form-control" value="@Model.phone">
                </div>

                <!-- Address -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Address</label>
                    <textarea name="address" class="form-control" rows="3">@Model.address</textarea>
                </div>

                <!-- Description -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Description</label>
                    <textarea name="description" class="form-control" rows="3">@Model.description</textarea>
                </div>

            </div>

            <!-- Submit -->
            <div class="text-center">
                <button type="submit" class="btn btn-primary fs-5 px-4">
                    Update
                </button>
            </div>

        </form>

    </div>
</div>

<!-- IMAGE PREVIEW SCRIPT -->
<script>
    function loadImage(event) {
        var reader = new FileReader();
        reader.onload = function () {
            document.getElementById('previewImg').src = reader.result;
        }
        reader.readAsDataURL(event.target.files[0]);
    }
</script>