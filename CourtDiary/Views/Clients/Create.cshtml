

@model CourtDiary.Models.Client

@{
    ViewData["Title"] = "Create Client";
}

<div class="container">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">

                <div class="col-sm-6">
                    <h4 class="mx-4">Add Client</h4>
                </div>

                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/Clients/Index">Client</a></li>
                        <li class="breadcrumb-item active">Add Client</li>
                    </ol>
                </div>

            </div>
        </div>
    </div>

    <!-- FORM -->
    <form method="post" enctype="multipart/form-data">

        <div class="card mx-4">
            <div class="card-body">

                <!-- IMAGE PREVIEW -->
                <div class="text-center">
                    <img id="previewImg"
                         src="~/images/user.jpg"
                         class="img-fluid img-circle"
                         style="width:125px; height:125px; object-fit:cover;"
                         alt="User">
                </div>

                <!-- FILE INPUT -->
                <div class="text-center mt-2">
                    <input type="file"
                           name="avatar"
                           id="avatar"
                           class="d-none"
                           accept="image/*"
                           onchange="loadImage(event)" />

                    <label for="avatar" class="btn btn-secondary btn-sm px-3">
                        Choose Image
                    </label>
                </div>

                <div class="row mx-1 my-3">

                    <!-- Name -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Client Name</label>
                        <input type="text" name="name" class="form-control" placeholder="Enter client name" required>
                    </div>

                    <!-- Phone -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Phone</label>
                        <input type="text" name="phone" class="form-control" placeholder="Enter phone number">
                    </div>

                    <!-- Address -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Address</label>
                        <textarea name="address" class="form-control" rows="3" placeholder="Enter address"></textarea>
                    </div>

                    <!-- Description -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="description" class="form-control" rows="3" placeholder="Enter description"></textarea>
                    </div>

                </div>

                <!-- Submit -->
                <div class="text-center">
                    <button type="submit" class="btn btn-primary fs-5 px-4">
                        Add
                    </button>
                </div>

            </div>
        </div>

    </form>
</div>

<!-- IMAGE PREVIEW SCRIPT -->
<script>
    function loadImage(event) {
        var reader = new FileReader();
        reader.onload = function () {
            document.getElementById('previewImg').src = reader.result;
        }
        reader.readAsDataURL(event.target.files[0]);
    }
</script>