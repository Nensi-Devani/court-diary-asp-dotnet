@model IEnumerable<CourtDiary.Models.Client>

@{
    ViewData["Title"] = "Admin Index";
    var users = ViewBag.Users as List<CourtDiary.Models.User> ?? new List<CourtDiary.Models.User>();
}
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <!-- Card Header -->
                <div class="card-header" style="display:flex; align-items:center;">
                    <h3 class="card-title">Clients</h3>
                    <div class="card-tools" style="margin-left:auto; display:flex; align-items:center; gap:10px;">
                        <!-- Search -->
                        <div class="search-box" style="position:relative; width:180px;">
                            <i class="fas fa-search"
                               style="position:absolute; top:50%; left:8px; transform:translateY(-50%); color:#6c757d; font-size:14px;"></i>
                            <input type="text" placeholder="Search"
                                   style="width:100%; height:30px; padding-left:30px; border:1px solid #ced4da; border-radius:5px; font-size:14px;">
                        </div>

                        <!-- Add New -->
                        <a class="btn btn-primary btn-sm"
                           asp-area="Admin"
                           asp-controller="Clients"
                           asp-action="Create">
                            <i class="fas fa-plus"></i> Add New
                        </a>
                    </div>
                </div>
                <!-- Card Body -->
                <div class="card-body p-0">
                    <table class="table table-striped w-100 text-center">
                        <thead>
                            <tr>
                                <th>Sr No</th>
                                <th>Client Image</th>
                                <th>Client Name</th>
                                <th>Mobile</th>
                                <th>Active Cases</th>
                                <th>Lawyer Name</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int counter = 1;
                            }
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@counter</td>
                                    <td>
                                        <img src="@(!string.IsNullOrEmpty(item.ImagePath) ? item.ImagePath : "/images/user.jpg")"
                                             class="profile-img"
                                             style="width:40px; height:40px; border-radius:10%;">
                                    </td>
                                    <td>@item.name</td>
                                    <td>@item.phone</td>
                                    <td>
                                        <span class="badge bg-success">0</span>
                                    </td>
                                    <td>@(users.FirstOrDefault(u => u.user_id == item.user_id)?.name ?? "N/A")</td>
                                    <td>
                                        <!-- View Button -->
                                        <a href="/Admin/Clients/Viewdetails/@item.client_id" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i>
                                        </a>

                                        <!-- Edit Button -->
                                        <a href="/Admin/Clients/Edit/@item.client_id" class="btn btn-sm btn-warning">
                                            <i class="fas fa-edit"></i>
                                        </a>

                                        <!-- Delete Button -->
                                        <form method="post" action="/Admin/Clients/Delete/@item.client_id" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this client?');">
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                counter++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>