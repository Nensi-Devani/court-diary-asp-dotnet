
@{
    ViewData["Title"] = " Lawyer Edit";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">

            <div class="col-sm-6">
                <h4 class="m-0">Edit Lawyer</h4>
            </div>

            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-controller="Lawyers" asp-action="Index">Lawyers</a></li>
                    <li class="breadcrumb-item active">Edit Lawyer</li>
                </ol>
            </div>

        </div>
    </div>
</div>


<div class="card mx-4">
    <div class="card-body">
        <form>

            <div class="text-center">
                <img src="~/images/user.jpg" class="image-fluid img-circle" style="width:125px;" alt="User">
            </div>

            <div class="text-center mt-2">
                <input type="file" name="avatar" id="avatar" class="d-none" />
                <label for="avatar" class="btn btn-secondary btn-sm px-3">Choose</label>
            </div>

            <div class="row mx-1 my-4">

                <!-- Lawyer Name -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Lawyer Name</label>
                    <input type="text" class="form-control" value="John Deo">
                </div>

                <!-- Mobile No -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Mobile No.</label>
                    <input type="text" class="form-control" value="1234567890">

                </div>

                <!-- Email -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" value="abc@gmail.com">
                </div>

                <!-- Office Email -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Office Email</label>
                    <input type="email" class="form-control" value="office@adv.com">
                </div>

                <!-- Office Contact No -->
                <div class="col-md-12 mb-3">
                    <label class="form-label">Office Contact No.</label>
                    <input type="text" class="form-control" value="1234567890">
                </div>

                <!-- Office Address -->
                <div class="col-md-12 mb-3">
                    <label class="form-label">Office Address</label>
                    <textarea class="form-control" rows="3">New York Street</textarea>
                </div>

            </div>

            <!-- Buttons -->
            <div class="text-center">
                <button type="submit" class="btn btn-primary fs-5 px-4">
                    Update
                </button>
            </div>

        </form>
    </div>
</div>


