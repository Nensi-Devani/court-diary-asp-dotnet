@model CourtDiary.Models.User

@{
    ViewData["Title"] = " Lawyer Edit";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">

            <div class="col-sm-6">
                <h4 class="m-0">Edit Lawyer</h4>
            </div>

            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item">
                        <a asp-controller="Lawyers" asp-action="Index">Lawyers</a>
                    </li>
                    <li class="breadcrumb-item active">Edit Lawyer</li>
                </ol>
            </div>

        </div>
    </div>
</div>

<div class="card mx-4">
    <div class="card-body">

        <form asp-action="Edit" method="post" enctype="multipart/form-data">

            <!-- Hidden ID -->
            <input type="hidden" asp-for="user_id" />

            <!-- Validation -->
            <div asp-validation-summary="All" class="text-danger"></div>

            <!-- IMAGE -->
            <div class="text-center">
                <img id="previewImg"
                     src="@(string.IsNullOrEmpty(Model.avatar) ? "/images/user.jpg" : Model.avatar)"
                     class="image-fluid img-circle"
                     style="width:125px; height:125px; object-fit:cover;"
                     alt="User">
            </div>

            <div class="text-center mt-2">
                <input type="file"
                       name="avatarFile"
                       id="avatar"
                       class="d-none"
                       onchange="loadImage(event)" />

                <label for="avatar" class="btn btn-secondary btn-sm px-3">Choose</label>
            </div>

            <div class="row mx-1 my-4">

                <!-- Name -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Lawyer Name</label>
                    <input asp-for="name" class="form-control">
                    <span asp-validation-for="name" class="text-danger"></span>
                </div>

                <!-- Email -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="email" class="form-control">
                    <span asp-validation-for="email" class="text-danger"></span>
                </div>

                <!-- Password -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Password</label>
                    <input asp-for="password" type="password" class="form-control">
                    <span asp-validation-for="password" class="text-danger"></span>
                </div>

                <!-- Office Email -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Office Email</label>
                    <input asp-for="office_email" class="form-control">
                </div>

                <!-- Office Contact -->
                <div class="col-md-12 mb-3">
                    <label class="form-label">Office Contact No.</label>
                    <input asp-for="office_phone_no" class="form-control">
                </div>

                <!-- Office Address -->
                <div class="col-md-12 mb-3">
                    <label class="form-label">Office Address</label>
                    <textarea asp-for="office_address" class="form-control" rows="3"></textarea>
                </div>

            </div>

            <!-- Button -->
            <div class="text-center">
                <button type="submit" class="btn btn-primary fs-5 px-4">
                    Update
                </button>
            </div>

        </form>
    </div>
</div>

<!-- IMAGE PREVIEW SCRIPT -->
<script>
    function loadImage(event) {
        var reader = new FileReader();
        reader.onload = function () {
            document.getElementById('previewImg').src = reader.result;
        }
        reader.readAsDataURL(event.target.files[0]);
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
