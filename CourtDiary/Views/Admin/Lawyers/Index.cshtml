
@{
    ViewData["Title"] = " Lawyer Index";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">

            <div class="card">

                <!-- Card Header -->

                <div class="card-header" style="display:flex; align-items:center;">

                    <h3 class="card-title">Lawyers</h3>

                    <div class="card-tools" style="margin-left:auto; display:flex; align-items:center; gap:10px;">

                        <!-- Search -->

                        <div class="search-box" style="position:relative; width:180px;">

                            <i class="fas fa-search"
                               style="position:absolute; top:50%; left:8px; transform:translateY(-50%); color:#6c757d; font-size:14px;"></i>

                            <input type="text" placeholder="Search"
                                   style="width:100%; height:30px; padding-left:30px; border:1px solid #ced4da; border-radius:5px; font-size:14px;">

                        </div>

                        <button class="btn btn-primary btn-add"
                                style="height:30px; padding:0 10px; font-size:14px;"
                                onclick="location.href='@Url.Action("Create", "Lawyers")'">
                            <i class="fas fa-plus"></i> Add New
                        </button>

                    </div>

                </div>
                <!-- Card Body -->
                <div class="card-body p-0">

                    <table class="table table-striped w-100 text-center">

                        <thead>
                            <tr>
                                <th>Sr No</th>
                                <th>Client</th>
                                <th>Lawyer Name</th>
                                <th>Mobile</th>
                                <th>Active Cases</th>
                                <th>Member Since</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>

                            @for (int i = 1; i <= 5; i++)
                            {
                                <tr>
                                    <td>@i</td>
                                    <td>
                                        <img src="~/images/user.jpg"
                                             class="profile-img"
                                             style="width:40px; height:40px; border-radius:10%;">
                                    </td>
                                    <td>John Doe</td>
                                    <td>9876543210</td>
                                    <td>
                                        <span class="badge bg-success">3</span>
                                    </td>
                                    <td>10-02-2026</td>
                                    <td>

                                        <!-- Meeting Button -->
                                        <button class="btn btn-sm btn-primary">
                                            <i class="fas fa-calendar"></i>
                                        </button>

                                        <!-- view Button -->
                                        <a asp-controller="Lawyers" asp-action="Viewlawyer" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i>
                                        </a>

                                        <!-- Edit Button -->
                                        <a asp-controller="Lawyers" asp-action="Edit" class="btn btn-sm btn-warning">
                                            <i class="fas fa-edit"></i>
                                        </a>

                                        <!-- Delete Button -->
                                        <button class="btn btn-sm btn-danger">
                                            <i class="fas fa-trash"></i>
                                        </button>



                                    </td>
                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>
    </div>
</div>



