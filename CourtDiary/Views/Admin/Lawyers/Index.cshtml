@model List<CourtDiary.Models.User>

@{
    ViewData["Title"] = " Lawyer Index";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">

            <div class="card">

                <!-- Card Header -->
                <div class="card-header" style="display:flex; align-items:center;">

                    <h3 class="card-title">Lawyers</h3>

                    <div class="card-tools" style="margin-left:auto; display:flex; align-items:center; gap:10px;">

                        <!-- Search -->
                        <div class="search-box" style="position:relative; width:180px;">
                            <i class="fas fa-search"
                               style="position:absolute; top:50%; left:8px; transform:translateY(-50%); color:#6c757d; font-size:14px;"></i>

                            <input type="text" placeholder="Search"
                                   style="width:100%; height:30px; padding-left:30px; border:1px solid #ced4da; border-radius:5px; font-size:14px;">
                        </div>

                        <a class="btn btn-primary btn-sm" asp-controller="Lawyers" asp-action="Create">
                            <i class="fas fa-plus"></i> Add New
                        </a>

                    </div>

                </div>

                <!-- Card Body -->
                <div class="card-body p-0">

                    <table class="table table-striped w-100 text-center">

                        <thead>
                            <tr>
                                <th>Sr No</th>
                                <th>Lawyer</th>
                                <th>Lawyer Name</th>
                                <th>Email</th>
                                <th>Office Contact</th>
                                <th>Member Since</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>

                            @if (Model != null && Model.Count > 0)
                            {
                                int i = 1;
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@i</td>

                                        <td>
                                            <img src="@(string.IsNullOrEmpty(item.avatar) ? "/images/user.jpg" : item.avatar)"
                                                 style="width:40px; height:40px; border-radius:50%; object-fit:cover;">
                                        </td>

                                        <td>@item.name</td>
                                        <td>@item.email</td>
                                        <td>@item.office_phone_no</td>
                                        <td>@item.created_at.ToString("dd-MM-yyyy")</td>

                                        <td>
                                            <a asp-action="Viewlawyer" asp-route-id="@item.user_id" class="btn btn-sm btn-info">
                                                <i class="fas fa-eye"></i>
                                            </a>

                                            <a asp-action="Edit" asp-route-id="@item.user_id" class="btn btn-sm btn-warning">
                                                <i class="fas fa-edit"></i>
                                            </a>

                                            <a asp-action="Delete" asp-route-id="@item.user_id" class="btn btn-sm btn-danger">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </td>
                                    </tr>

                                    i++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7">No Data Found</td>
                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>
    </div>
</div>