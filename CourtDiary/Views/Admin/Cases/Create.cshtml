@{
    ViewData["Title"] = "Add Admin Cases";
    var lawyers = ViewBag.Lawyers as IEnumerable<CourtDiary.Models.User>;
    var clients = ViewBag.Clients as IEnumerable<CourtDiary.Models.Client>;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h4 class="m-0">Add Case</h4>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/Admin/Cases/Index">Cases</a></li>
                    <li class="breadcrumb-item active">Add Case</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<form method="post" action="/Admin/Cases/Create" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <!-- ========== CASE DETAILS ========== -->
    <div class="card mx-4 mb-4">
        <div class="card-body">
            <h5><b>Case Details:</b></h5>

            <div class="row mt-3">

                <div class="col ">
                    <label>Case No</label>
                    <input type="text" name="case_no" class="form-control">
                </div>

                <div class="col-md-5 mb-3">
                    <label>Case Title</label>
                    <input type="text" name="title" class="form-control">
                </div>

                <div class="col-md-3 mb-3">
                    <label>Status</label>
                    <select name="status" class="form-control">
                        <option value="Active">Active</option>
                        <option value="Pending">Pending</option>
                        <option value="Closed">Closed</option>
                    </select>
                </div>


                <div class="col-md-6 mb-3">
                    <label>Case First Hearing</label>
                    <input type="date" class="form-control" name="firstHearingDate">
                </div>

                <div class="col-md-6 mb-3">
                    <label>Case Next Hearing</label>
                    <input type="date" class="form-control" name="nextHearingDate">
                </div>

                <div class="col-md-6 mb-3">
                    <label>Previous Hearing</label>
                    <input type="date" class="form-control" name="previousHearingDate">
                </div>

                <div class="col-md-6 mb-3">
                    <label>Location</label>
                    <input type="text" name="location" class="form-control">
                </div>

                <div class="col-md-6 mb-3">
                    <label>Hearing Notes</label>
<textarea class="form-control" name="hearing_notes" rows="3"></textarea>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Previous Hearing Summary</label>
<textarea class="form-control" name="previous_hearing_summary" rows="3"></textarea>
                </div>

                <div class="col-md-12 mb-3">
                    <label>Case Description</label>
<textarea class="form-control" name="description" rows="3"></textarea>
                </div>

            </div>

        </div>
    </div>


    <!-- Document Section -->
    <div class="card mx-4 mb-4">
        <div class="card-body">

            <h5><b>Document:</b></h5>

            <div class="row mt-3 align-items-center">

                <div class="col-md-6">
                    <input type="file" name="uploadedFiles" class="form-control-file w-100" multiple>
                </div>

                <div class="col-md-6 text-md-right mt-2 mt-md-0">
                    <select name="docCategory" class="form-control d-inline-block w-auto">
                        <option value="1">Court</option>
                        <option value="2">Evidence</option>
                        <option value="3">Client</option>
                    </select>
                </div>

            </div>

        </div>
    </div>


    <!-- ========== LAWYER DETAILS ========== -->
    <div class="card mx-4 mb-4">
        <div class="card-body">
            <h5><b>Lawyer Details:</b></h5>
            <div class="d-flex align-items-center mt-2">
                <div id="selectedLawyerPreview" class="mr-3" style="display:none !important;">
                    <img id="lawyerAvatar" src="/images/user.jpg" style="width:50px; height:50px; border-radius:50%; object-fit:cover; border:2px solid #007bff;">
                </div>
                <div>
                    <p id="lawyerNameDisplay" class="mb-1 font-weight-bold text-muted">No lawyer selected</p>
                    <button type="button" class="btn btn-success btn-sm" data-toggle="modal" data-target="#lawyerModal">
                        <i class="fas fa-user-tie mr-1"></i> Choose Lawyer
                    </button>
                </div>
            </div>
            <input type="hidden" name="user_id" id="selectedLawyerId" />
        </div>
    </div>

    <!-- Lawyer Modal -->
    <div class="modal fade" id="lawyerModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-user-tie mr-2"></i>Select Lawyer</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body p-0" style="max-height:420px; overflow-y:auto;">
                    <!-- Search inside modal -->
                    <div class="p-3 border-bottom">
                        <input type="text" id="lawyerSearch" class="form-control form-control-sm" placeholder="Search lawyer..." onkeyup="filterModal('lawyerSearch','lawyerTableBody')">
                    </div>
                    <table class="table table-striped table-hover w-100 text-center mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>#</th>
                                <th>Photo</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Member Since</th>
                                <th>Select</th>
                            </tr>
                        </thead>
                        <tbody id="lawyerTableBody">
                            @if (lawyers != null && lawyers.Any())
                            {
                                int i = 1;
                                foreach (var l in lawyers)
                                {
                                    <tr>
                                        <td>@i</td>
                                        <td>
                                            <img src="@(!string.IsNullOrEmpty(l.avatar) ? l.avatar : "/images/user.jpg")"
                                                 style="width:38px; height:38px; border-radius:50%; object-fit:cover;">
                                        </td>
                                        <td>@l.name</td>
                                        <td>@l.email</td>
                                        <td>@l.office_phone_no</td>
                                        <td>@l.created_at.ToString("dd-MM-yyyy")</td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-primary"
                                                    onclick="selectLawyer(@l.user_id, '@l.name', '@(!string.IsNullOrEmpty(l.avatar) ? l.avatar : "/images/user.jpg")')">
                                                <i class="fas fa-check"></i> Select
                                            </button>
                                        </td>
                                    </tr>
                                    i++;
                                }
                            }
                            else
                            {
                                <tr><td colspan="7" class="text-muted py-3">No lawyers found.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ========== CLIENT DETAILS ========== -->
    <div class="card mx-4 mb-4">
        <div class="card-body">
            <h5><b>Client Details:</b></h5>
            <div class="d-flex align-items-center mt-2">
                <div id="selectedClientPreview" class="mr-3" style="display:none !important;">
                    <img id="clientAvatar" src="/images/user.jpg" style="width:50px; height:50px; border-radius:50%; object-fit:cover; border:2px solid #28a745;">
                </div>
                <div>
                    <p id="clientNameDisplay" class="mb-1 font-weight-bold text-muted">No client selected</p>
                    <button type="button" class="btn btn-success btn-sm" data-toggle="modal" data-target="#clientModal">
                        <i class="fas fa-user mr-1"></i> Choose Client
                    </button>
                </div>
            </div>
            <input type="hidden" name="client_id" id="selectedClientId" />
        </div>
    </div>

    <!-- Client Modal -->
    <div class="modal fade" id="clientModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-user mr-2"></i>Select Client</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body p-0" style="max-height:420px; overflow-y:auto;">
                    <div class="p-3 border-bottom">
                        <input type="text" id="clientSearch" class="form-control form-control-sm" placeholder="Search client..." onkeyup="filterModal('clientSearch','clientTableBody')">
                    </div>
                    <table class="table table-striped table-hover w-100 text-center mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>#</th>
                                <th>Photo</th>
                                <th>Client Name</th>
                                <th>Mobile</th>
                                <th>Address</th>
                                <th>Select</th>
                            </tr>
                        </thead>
                        <tbody id="clientTableBody">
                            @if (clients != null && clients.Any())
                            {
                                int i = 1;
                                foreach (var cl in clients)
                                {
                                    <tr>
                                        <td>@i</td>
                                        <td>
                                            <img src="@(!string.IsNullOrEmpty(cl.ImagePath) ? cl.ImagePath : "/images/user.jpg")"
                                                 style="width:38px; height:38px; border-radius:50%; object-fit:cover;">
                                        </td>
                                        <td>@cl.name</td>
                                        <td>@cl.phone</td>
                                        <td>@cl.address</td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-primary"
                                                    onclick="selectClient(@cl.client_id, '@cl.name', '@(!string.IsNullOrEmpty(cl.ImagePath) ? cl.ImagePath : "/images/user.jpg")')">
                                                <i class="fas fa-check"></i> Select
                                            </button>
                                        </td>
                                    </tr>
                                    i++;
                                }
                            }
                            else
                            {
                                <tr><td colspan="6" class="text-muted py-3">No clients found.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ========== OPPOSITE PARTY ========== -->
    <div class="card mx-4 mb-4">
        <div class="card-body">
            <h5><b>Opposite Party Details:</b></h5>
            <div class="row mt-3">

                <!-- Opposite Party -->
                <div class="col-md-6 text-center">
                    <img id="oppPartyImg" src="/images/user.jpg" width="90" class="img-circle mb-2" style="height:90px; object-fit:cover;">
                    <br>
                    <input type="file" name="oppPartyAvatarFile" id="oppPartyFile" class="d-none"
                           onchange="previewImg(this, 'oppPartyImg')">
                    <label for="oppPartyFile" class="btn btn-secondary btn-sm">Choose Photo</label>

                    <div class="mt-3 text-left">
                        <label>Opposite Party Name</label>
                        <input type="text" name="oppPartyName" class="form-control" placeholder="Name">

                        <label class="mt-2">Other Notes (Opp. Party)</label>
                        <textarea name="oppPartyNotes" class="form-control" rows="2" placeholder="Notes..."></textarea>
                    </div>
                </div>

                <!-- Opposite Party Lawyer -->
                <div class="col-md-6 text-center">
                    <img id="oppLawyerImg" src="/images/user.jpg" width="90" class="img-circle mb-2" style="height:90px; object-fit:cover;">
                    <br>
                    <input type="file" name="oppLawyerAvatarFile" id="oppLawyerFile" class="d-none"
                           onchange="previewImg(this, 'oppLawyerImg')">
                    <label for="oppLawyerFile" class="btn btn-secondary btn-sm">Choose Photo</label>

                    <div class="mt-3 text-left">
                        <label>Opposite Party's Lawyer Name</label>
                        <input type="text" name="oppLawyerName" class="form-control" placeholder="Lawyer name">

                        <label class="mt-2">Other Notes (Lawyer)</label>
                        <textarea name="oppLawyerNotes" class="form-control" rows="2" placeholder="Notes..."></textarea>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Submit -->
    <div class="text-center mb-4">
        <button type="submit" class="btn btn-primary px-5 mb-4">
           Add 
        </button>
    </div>

</form>

<script>
    function selectLawyer(id, name, avatar) {
        document.getElementById('selectedLawyerId').value = id;
        document.getElementById('lawyerNameDisplay').textContent = 'Selected: ' + name;
        document.getElementById('lawyerNameDisplay').classList.remove('text-muted');
        document.getElementById('lawyerNameDisplay').classList.add('text-success');
        document.getElementById('lawyerAvatar').src = avatar;
        document.getElementById('selectedLawyerPreview').style.display = 'block';
        $('#lawyerModal').modal('hide');
    }

    function selectClient(id, name, avatar) {
        document.getElementById('selectedClientId').value = id;
        document.getElementById('clientNameDisplay').textContent = 'Selected: ' + name;
        document.getElementById('clientNameDisplay').classList.remove('text-muted');
        document.getElementById('clientNameDisplay').classList.add('text-success');
        document.getElementById('clientAvatar').src = avatar;
        document.getElementById('selectedClientPreview').style.display = 'block';
        $('#clientModal').modal('hide');
    }

    function previewImg(input, imgId) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById(imgId).src = e.target.result;
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function filterModal(inputId, bodyId) {
        var query = document.getElementById(inputId).value.toLowerCase();
        var rows = document.querySelectorAll('#' + bodyId + ' tr');
        rows.forEach(function(row) {
            row.style.display = row.innerText.toLowerCase().includes(query) ? '' : 'none';
        });
    }
</script>