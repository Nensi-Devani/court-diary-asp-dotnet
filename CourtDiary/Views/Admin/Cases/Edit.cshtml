@model CourtDiary.Models.Case
@{
    ViewData["Title"] = "Edit Admin Case";
    var lawyers = ViewBag.Lawyers as IEnumerable<CourtDiary.Models.User>;
    var clients = ViewBag.Clients as IEnumerable<CourtDiary.Models.Client>;
    var hearing = Model.Hearings?.FirstOrDefault();
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h4 class="m-0">Edit Case</h4>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/Admin/Cases/Index">Cases</a></li>
                    <li class="breadcrumb-item active">Edit Case</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<form method="post" action="/Admin/Cases/Edit" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" name="case_id" value="@Model.case_id" />

    <!-- ========== CASE DETAILS ========== -->
    <div class="card mx-4 mb-4">
        <div class="card-body">
            <h5><b>Case Details:</b></h5>
            <div class="row mt-3">

                <div class="col-md-6 mb-3">
                    <label>Case No <span class="text-danger">*</span></label>
                    <input type="text" name="case_no" class="form-control" value="@Model.case_no" required>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Case Title <span class="text-danger">*</span></label>
                    <input type="text" name="title" class="form-control" value="@Model.title" required>
                </div>

                <div class="col-md-6 mb-3">
                    <label>First Hearing Date</label>
                    <input type="date" name="firstHearingDate" class="form-control"
                           value="@(hearing?.hearing_date?.ToString("yyyy-MM-dd"))">
                </div>

                <div class="col-md-6 mb-3">
                    <label>Next Hearing Date</label>
                    <input type="date" name="nextHearingDate" class="form-control"
                           value="@(hearing?.next_hearing_date?.ToString("yyyy-MM-dd"))">
                </div>

                <div class="col-md-6 mb-3">
                    <label>Location</label>
                    <input type="text" name="location" class="form-control" value="@Model.location">
                </div>

                <div class="col-md-6 mb-3">
                    <label>Case Status</label>
                    <select name="status" class="form-control">
                        @if (Model.status == "Active") { <option value="Active" selected>Active</option> } else { <option value="Active">Active</option> }
                        @if (Model.status == "Pending") { <option value="Pending" selected>Pending</option> } else { <option value="Pending">Pending</option> }
                        @if (Model.status == "Closed") { <option value="Closed" selected>Closed</option> } else { <option value="Closed">Closed</option> }
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Hearing Notes</label>
                    <textarea name="hearing_notes" class="form-control" rows="3">@Model.hearing_notes</textarea>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Previous Hearing Summary</label>
                    <textarea name="previous_hearing_summary" class="form-control" rows="3">@Model.previous_hearing_summary</textarea>
                </div>

                <div class="col-md-12 mb-3">
                    <label>Case Description</label>
                    <textarea name="description" class="form-control" rows="3">@Model.description</textarea>
                </div>

            </div>
        </div>
    </div>

    <!-- ========== LAWYER ========== -->
    @{
        var currentLawyer = lawyers?.FirstOrDefault(l => l.user_id == Model.user_id);
    }
    <div class="card mx-4 mb-4">
        <div class="card-body">
            <h5><b>Lawyer Details:</b></h5>
            <div class="d-flex align-items-center mt-2">
                <div class="mr-3">
                    <img id="lawyerAvatar"
                         src="@(!string.IsNullOrEmpty(currentLawyer?.avatar) ? currentLawyer.avatar : "/images/user.jpg")"
                         style="width:50px; height:50px; border-radius:50%; object-fit:cover; border:2px solid #007bff;">
                </div>
                <div>
                    <p id="lawyerNameDisplay" class="mb-1 font-weight-bold @(currentLawyer != null ? "text-success" : "text-muted")">
                        @(currentLawyer != null ? "Selected: " + currentLawyer.name : "No lawyer selected")
                    </p>
                    <button type="button" class="btn btn-success btn-sm" data-toggle="modal" data-target="#lawyerModal">
                        <i class="fas fa-user-tie mr-1"></i> Change Lawyer
                    </button>
                </div>
            </div>
            <input type="hidden" name="user_id" id="selectedLawyerId" value="@Model.user_id" />
        </div>
    </div>

    <!-- Lawyer Modal -->
    <div class="modal fade" id="lawyerModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-user-tie mr-2"></i>Select Lawyer</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body p-0" style="max-height:420px; overflow-y:auto;">
                    <div class="p-3 border-bottom">
                        <input type="text" id="lawyerSearch" class="form-control form-control-sm" placeholder="Search..."
                               onkeyup="filterModal('lawyerSearch','lawyerTableBody')">
                    </div>
                    <table class="table table-striped table-hover w-100 text-center mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>#</th><th>Photo</th><th>Name</th><th>Email</th><th>Phone</th><th>Select</th>
                            </tr>
                        </thead>
                        <tbody id="lawyerTableBody">
                            @if (lawyers != null)
                            {
                                int i = 1;
                                foreach (var l in lawyers)
                                {
                                    <tr>
                                        <td>@i</td>
                                        <td><img src="@(!string.IsNullOrEmpty(l.avatar) ? l.avatar : "/images/user.jpg")"
                                                 style="width:38px;height:38px;border-radius:50%;object-fit:cover;"></td>
                                        <td>@l.name</td>
                                        <td>@l.email</td>
                                        <td>@l.office_phone_no</td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-primary"
                                                    onclick="selectLawyer(@l.user_id, '@l.name', '@(!string.IsNullOrEmpty(l.avatar) ? l.avatar : "/images/user.jpg")')">
                                                <i class="fas fa-check"></i> Select
                                            </button>
                                        </td>
                                    </tr>
                                    i++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer"><button class="btn btn-secondary" data-dismiss="modal">Close</button></div>
            </div>
        </div>
    </div>

    <!-- ========== CLIENT ========== -->
    @{
        var currentClient = clients?.FirstOrDefault(c => c.client_id == Model.client_id);
    }
    <div class="card mx-4 mb-4">
        <div class="card-body">
            <h5><b>Client Details:</b></h5>
            <div class="d-flex align-items-center mt-2">
                <div class="mr-3">
                    <img id="clientAvatar"
                         src="@(!string.IsNullOrEmpty(currentClient?.ImagePath) ? currentClient.ImagePath : "/images/user.jpg")"
                         style="width:50px; height:50px; border-radius:50%; object-fit:cover; border:2px solid #28a745;">
                </div>
                <div>
                    <p id="clientNameDisplay" class="mb-1 font-weight-bold @(currentClient != null ? "text-success" : "text-muted")">
                        @(currentClient != null ? "Selected: " + currentClient.name : "No client selected")
                    </p>
                    <button type="button" class="btn btn-success btn-sm" data-toggle="modal" data-target="#clientModal">
                        <i class="fas fa-user mr-1"></i> Change Client
                    </button>
                </div>
            </div>
            <input type="hidden" name="client_id" id="selectedClientId" value="@Model.client_id" />
        </div>
    </div>

    <!-- Client Modal -->
    <div class="modal fade" id="clientModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-user mr-2"></i>Select Client</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body p-0" style="max-height:420px; overflow-y:auto;">
                    <div class="p-3 border-bottom">
                        <input type="text" id="clientSearch" class="form-control form-control-sm" placeholder="Search..."
                               onkeyup="filterModal('clientSearch','clientTableBody')">
                    </div>
                    <table class="table table-striped table-hover w-100 text-center mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>#</th><th>Photo</th><th>Name</th><th>Mobile</th><th>Address</th><th>Select</th>
                            </tr>
                        </thead>
                        <tbody id="clientTableBody">
                            @if (clients != null)
                            {
                                int i = 1;
                                foreach (var cl in clients)
                                {
                                    <tr>
                                        <td>@i</td>
                                        <td><img src="@(!string.IsNullOrEmpty(cl.ImagePath) ? cl.ImagePath : "/images/user.jpg")"
                                                 style="width:38px;height:38px;border-radius:50%;object-fit:cover;"></td>
                                        <td>@cl.name</td>
                                        <td>@cl.phone</td>
                                        <td>@cl.address</td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-primary"
                                                    onclick="selectClient(@cl.client_id, '@cl.name', '@(!string.IsNullOrEmpty(cl.ImagePath) ? cl.ImagePath : "/images/user.jpg")')">
                                                <i class="fas fa-check"></i> Select
                                            </button>
                                        </td>
                                    </tr>
                                    i++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer"><button class="btn btn-secondary" data-dismiss="modal">Close</button></div>
            </div>
        </div>
    </div>

    <!-- Update Button -->
    <div class="text-center mb-4">
        
        <button type="submit" class="btn btn-primary px-5">
             Update 
        </button>
    </div>

</form>

<script>
    function selectLawyer(id, name, avatar) {
        document.getElementById('selectedLawyerId').value = id;
        document.getElementById('lawyerNameDisplay').textContent = 'Selected: ' + name;
        document.getElementById('lawyerNameDisplay').className = 'mb-1 font-weight-bold text-success';
        document.getElementById('lawyerAvatar').src = avatar;
        $('#lawyerModal').modal('hide');
    }

    function selectClient(id, name, avatar) {
        document.getElementById('selectedClientId').value = id;
        document.getElementById('clientNameDisplay').textContent = 'Selected: ' + name;
        document.getElementById('clientNameDisplay').className = 'mb-1 font-weight-bold text-success';
        document.getElementById('clientAvatar').src = avatar;
        $('#clientModal').modal('hide');
    }

    function filterModal(inputId, bodyId) {
        var query = document.getElementById(inputId).value.toLowerCase();
        document.querySelectorAll('#' + bodyId + ' tr').forEach(function(row) {
            row.style.display = row.innerText.toLowerCase().includes(query) ? '' : 'none';
        });
    }
</script>
